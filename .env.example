# EarCrawler facade defaults for curl/HTTPie workflows
EAR_BASE_URL=http://localhost:9001
# Used only when the local-validation flag -IncludeQuarantinedSearch is set
EAR_SEARCH_QUERY=export controls
# Leave EAR_API_KEY empty to fall back to the TRADEGOV_API_KEY environment variable
EAR_API_KEY=
# Optional fixed entity identifier; defaults to urn:ear:entity:demo when blank
EAR_ENTITY_ID=
